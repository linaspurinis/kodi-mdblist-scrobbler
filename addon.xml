<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.mdblist-scrobbler" name="MDBList Scrobbler" version="1.2.0" provider-name="MDBList">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.22.0"/>
    </requires>
    <extension point="xbmc.service" library="service.py"/>
    <extension point="xbmc.python.script" library="script.py"/>
    <extension point="xbmc.python.pluginsource" library="plugin.py">
        <provides>video</provides>
    </extension>
    <extension point="kodi.context.item">
        <menu id="kodi.core.main">
            <item library="resources/lib/watchlist_context.py" args="add">
                <label>Add to MDBList watchlist</label>
                <visible>String.IsEqual(ListItem.dbtype,movie) | String.IsEqual(ListItem.dbtype,tvshow) | String.IsEqual(ListItem.dbtype,episode)</visible>
            </item>
        </menu>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <summary lang="en">MDBList Scrobbler</summary>
        <description lang="en">Track watched TV shows and movies with MDBList scrobble endpoints</description>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
